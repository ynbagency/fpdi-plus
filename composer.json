{
    "name": "ynbagency/fpdi-plus",
    "description": "A self-contained PDF import and manipulation toolkit that bundles a namespaced fork of FPDI and FPDF. Merge, extract, split, watermark, in-memory input and string output, with no external PDF dependencies.",
    "type": "library",
    "keywords": ["pdf", "fpdi", "fpdf", "import", "template", "merge", "split"],
    "license": "MIT",
    "homepage": "https://github.com/ynbagency/fpdi-plus",
    "authors": [
        {
            "name": "YNB Agency",
            "email": "ynb.agency@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/ynbagency/fpdi-plus/issues",
        "source": "https://github.com/ynbagency/fpdi-plus"
    },
    "require": {
        "php": ">=8.1",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "suggest": {
        "ext-gd": "Only needed if you embed raster images (JPEG/PNG/GIF) via the bundled engine's Image() method."
    },
    "autoload": {
        "psr-4": {
            "YnbAgency\\Fpdi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YnbAgency\\Fpdi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "coverage": "phpunit --coverage-text",
        "analyse": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "check": [
            "@cs",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
